[{"id":12673,"slug":"lawyer-landing-68","title":"Lawyer Landing Page Template","code":"<!DOCTYPE html>\n<html lang=\"pl\" class=\"scroll-smooth\">\n<head>\n<script>\ntry{if(window.parent&&window.parent!==window){window.parent.promotekit_referral=\"1fd2949a-d22c-431b-92bf-02d4ad04ee24\";window.parent.document.cookie=\"promotekit_referral=1fd2949a-d22c-431b-92bf-02d4ad04ee24;path=/;domain=.aura.build;max-age=31536000\"}}catch(e){}\n</script>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>Adwokat Michał Bukowski - Kancelaria Prawna Kielce</title>\n<meta name=\"description\" content=\"Skuteczna obrona w sprawach karnych i rodzinnych. Profesjonalna kancelaria adwokacka w Kielcach. Umów poradę.\">\n<script src=\"https://cdn.tailwindcss.com\"></script>\n<script src=\"https://cdnjs.cloudflare.com/ajax/libs/iconify/2.0.0/iconify.min.js\"></script>\n<script>\ntailwind.config = {\ntheme: {\nextend: {\nfontFamily: {\nsans: ['system-ui', '-apple-system', 'Segoe UI', 'Roboto', 'Helvetica Neue', 'Arial', 'sans-serif'],\n},\ncolors: {\nnavy: {\n800: '#1e293b',\n900: '#0f172a',\n},\ngold: {\n500: '#d4af37',\n600: '#b4941f',\n}\n},\nboxShadow: {\n'glow': '0 0 20px rgba(212, 175, 55, 0.15)',\n}\n}\n}\n}\n</script>\n<style>\nbody {\n-webkit-font-smoothing: antialiased;\n-moz-osx-font-smoothing: grayscale;\n}\n/* Custom UI Elements */\n.glass-panel {\nbackground: rgba(255, 255, 255, 0.03);\nbackdrop-filter: blur(10px);\nborder: 1px solid rgba(255, 255, 255, 0.1);\n}\n.custom-check input:checked + div {\nbackground-color: #d4af37;\nborder-color: #d4af37;\n}\n/* Subtle animations */\n.fade-in-up {\nanimation: fadeInUp 0.8s ease-out forwards;\n}\n@keyframes fadeInUp {\nfrom { opacity: 0; transform: translateY(20px); }\nto { opacity: 1; transform: translateY(0); }\n}\n</style></head>\n<body class=\"bg-slate-50 text-slate-600 font-sans antialiased selection:bg-gold-500 selection:text-white\">\n\n    <!-- HERO SECTION with Background Image -->\n    <header class=\"relative w-full min-h-[100vh] md:min-h-[850px] flex flex-col justify-center overflow-hidden\">\n        \n        <!-- Background Image & Overlay -->\n        <div class=\"absolute inset-0 z-0\">\n            <img src=\"https://bukowski-kielce.pl/wp-content/uploads/2024/06/IMG_2679-scaled-1.jpg\" alt=\"Background\" class=\"w-full h-full object-cover object-top opacity-100\">\n            <!-- Dark Overlay Gradient -->\n            <div class=\"absolute inset-0 bg-gradient-to-r from-navy-900/95 via-navy-900/80 to-navy-900/40 mix-blend-multiply\"></div>\n            <div class=\"absolute inset-0 bg-gradient-to-t from-navy-900 via-transparent to-transparent\"></div>\n        </div>\n\n        <!-- Navigation (Overlay) -->\n        <nav class=\"absolute top-0 w-full z-50 border-b border-white/10\">\n            <div class=\"max-w-7xl mx-auto px-6 py-6 flex justify-between items-center\">\n                <div class=\"flex items-center gap-3 text-white\">\n                    <div class=\"w-10 h-10 bg-gold-500 rounded flex items-center justify-center text-navy-900\">\n                        <span class=\"iconify w-6 h-6\" data-icon=\"lucide:scale\" data-stroke-width=\"1.5\"></span>\n                    </div>\n                    <div>\n                        <span class=\"block text-lg font-semibold tracking-tight leading-none\">MICHAŁ BUKOWSKI</span>\n                        <span class=\"block text-xs text-white/60 tracking-[0.2em] uppercase mt-1\">Kancelaria Adwokacka</span>\n                    </div>\n                </div>\n                <div class=\"hidden md:flex items-center gap-8 text-sm font-medium text-white/80\">\n                    <a href=\"#o-mnie\" class=\"hover:text-white transition\">O mnie</a>\n                    <a href=\"#specjalizacje\" class=\"hover:text-white transition\">Specjalizacje</a>\n                    <a href=\"#kontakt\" class=\"hover:text-white transition\">Kontakt</a>\n                    <a href=\"tel:+48664314578\" class=\"px-5 py-2.5 bg-white/10 hover:bg-white/20 border border-white/10 rounded text-white transition backdrop-blur-sm flex items-center gap-2\">\n                        <span class=\"iconify\" data-icon=\"lucide:phone\" data-stroke-width=\"1.5\"></span>\n                        +48 664 314 578\n                    </a>\n                </div>\n            </div>\n        </nav>\n\n        <!-- Main Hero Content -->\n        <div class=\"relative z-10 max-w-7xl mx-auto px-6 grid lg:grid-cols-12 gap-12 lg:gap-20 items-center pt-20\">\n            \n            <!-- Left Text Column -->\n            <div class=\"lg:col-span-7 space-y-8 fade-in-up\">\n                <div class=\"inline-flex items-center gap-2 px-3 py-1 rounded-full bg-gold-500/10 border border-gold-500/20 text-gold-500 text-xs font-medium uppercase tracking-wide\">\n                    <span class=\"w-1.5 h-1.5 rounded-full bg-gold-500 animate-pulse\"></span>\n                    Skuteczna obrona prawna\n                </div>\n\n                <h1 class=\"text-4xl md:text-6xl lg:text-7xl font-semibold text-white tracking-tight leading-[1.05]\">\n                    Bezpieczeństwo <br>\n                    w <span class=\"text-transparent bg-clip-text bg-gradient-to-r from-gold-500 to-amber-200\">trudnych</span> sprawach.\n                </h1>\n                \n                <p class=\"text-lg md:text-xl text-slate-300 max-w-xl font-light leading-relaxed\">\n                    Specjalistyczna pomoc w sprawach karnych i rodzinnych. Indywidualna strategia obrony i pełna dyskrecja na każdym etapie postępowania.\n                </p>\n\n                <div class=\"flex flex-col sm:flex-row gap-4 pt-4\">\n                    <a href=\"#contact-card\" class=\"px-8 py-4 bg-white text-navy-900 rounded font-medium text-center hover:bg-slate-100 transition shadow-[0_0_20px_rgba(255,255,255,0.15)]\">\n                        Bezpłatna wycena sprawy\n                    </a>\n                    <a href=\"#specjalizacje\" class=\"px-8 py-4 border border-white/20 text-white rounded font-medium text-center hover:bg-white/5 transition flex items-center justify-center gap-2\">\n                        Zobacz specjalizacje\n                        <span class=\"iconify\" data-icon=\"lucide:arrow-down\" data-stroke-width=\"1.5\"></span>\n                    </a>\n                </div>\n\n                <div class=\"pt-8 border-t border-white/10 grid grid-cols-3 gap-6\">\n                    <div>\n                        <p class=\"text-3xl font-semibold text-white tracking-tight\">15+</p>\n                        <p class=\"text-xs text-slate-400 uppercase mt-1\">Lat praktyki</p>\n                    </div>\n                    <div>\n                        <p class=\"text-3xl font-semibold text-white tracking-tight\">500+</p>\n                        <p class=\"text-xs text-slate-400 uppercase mt-1\">Spraw</p>\n                    </div>\n                    <div>\n                        <p class=\"text-3xl font-semibold text-white tracking-tight\">24h</p>\n                        <p class=\"text-xs text-slate-400 uppercase mt-1\">Kontakt</p>\n                    </div>\n                </div>\n            </div>\n\n            <!-- Right Form Column -->\n            <div class=\"lg:col-span-5\" id=\"contact-card\">\n                <div class=\"bg-white p-8 rounded-2xl shadow-2xl relative overflow-hidden\">\n                    <div class=\"absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-gold-500 to-navy-900\"></div>\n                    \n                    <div class=\"mb-6\">\n                        <h3 class=\"text-2xl font-semibold text-navy-900 tracking-tight\">Opisz swój problem</h3>\n                        <p class=\"text-sm text-slate-500 mt-1\">Oddzwonię z propozycją strategii działania.</p>\n                    </div>\n\n                    <form id=\"heroForm\" class=\"space-y-4\">\n                        <div class=\"grid grid-cols-2 gap-4\">\n                            <div>\n                                <label class=\"block text-xs font-medium text-slate-700 mb-1 uppercase tracking-wide\">Imię</label>\n                                <input type=\"text\" required class=\"w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded text-navy-900 focus:outline-none focus:ring-1 focus:ring-navy-900 focus:border-navy-900 transition placeholder-slate-400\" placeholder=\"Jan\">\n                            </div>\n                            <div>\n                                <label class=\"block text-xs font-medium text-slate-700 mb-1 uppercase tracking-wide\">Telefon</label>\n                                <input type=\"tel\" required class=\"w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded text-navy-900 focus:outline-none focus:ring-1 focus:ring-navy-900 focus:border-navy-900 transition placeholder-slate-400\" placeholder=\"000-000-000\">\n                            </div>\n                        </div>\n\n                        <div>\n                            <label class=\"block text-xs font-medium text-slate-700 mb-1 uppercase tracking-wide\">Kategoria sprawy</label>\n                            <div class=\"relative\">\n                                <select class=\"w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded text-navy-900 appearance-none focus:outline-none focus:ring-1 focus:ring-navy-900 transition cursor-pointer\">\n                                    <option>Sprawa karna</option>\n                                    <option>Rozwód / Rodzinna</option>\n                                    <option>Odszkodowanie</option>\n                                    <option>Inna sprawa</option>\n                                </select>\n                                <span class=\"iconify absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none\" data-icon=\"lucide:chevron-down\"></span>\n                            </div>\n                        </div>\n\n                        <div>\n                            <label class=\"block text-xs font-medium text-slate-700 mb-1 uppercase tracking-wide\">Krótki opis</label>\n                            <textarea rows=\"3\" class=\"w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded text-navy-900 focus:outline-none focus:ring-1 focus:ring-navy-900 transition placeholder-slate-400 resize-none\" placeholder=\"Czego dotyczy sprawa?\"></textarea>\n                        </div>\n\n                        <label class=\"custom-check flex items-start gap-3 cursor-pointer group\">\n                            <input type=\"checkbox\" required class=\"peer sr-only\">\n                            <div class=\"w-4 h-4 mt-0.5 border border-slate-300 rounded flex-shrink-0 flex items-center justify-center transition peer-checked:bg-navy-900 peer-checked:border-navy-900\">\n                                <span class=\"iconify text-white text-xs opacity-0 peer-checked:opacity-100\" data-icon=\"lucide:check\"></span>\n                            </div>\n                            <span class=\"text-[10px] text-slate-400 leading-tight\">\n                                Wyrażam zgodę na przetwarzanie danych osobowych w celu kontaktu.\n                            </span>\n                        </label>\n\n                        <button type=\"submit\" class=\"w-full py-4 bg-navy-900 text-white font-medium rounded hover:bg-navy-800 transition shadow-lg shadow-navy-900/20 flex items-center justify-center gap-2 group\">\n                            Prześlij zgłoszenie\n                            <span class=\"iconify group-hover:translate-x-1 transition-transform\" data-icon=\"lucide:arrow-right\" data-stroke-width=\"2\"></span>\n                        </button>\n                    </form>\n                </div>\n            </div>\n        </div>\n    </header>\n\n    <!-- TRUST STRIP -->\n    <section class=\"bg-navy-900 border-b border-white/5 py-10 relative overflow-hidden\">\n        <div class=\"max-w-7xl mx-auto px-6 flex flex-wrap justify-center md:justify-between items-center gap-8 opacity-60 grayscale hover:grayscale-0 transition duration-500\">\n            <!-- Simulated Client Logos/Badges (Text Based for purity) -->\n            <div class=\"flex items-center gap-2 text-white font-medium text-lg tracking-tight\">\n                <span class=\"iconify w-6 h-6\" data-icon=\"lucide:shield-check\"></span> Bezpieczeństwo\n            </div>\n            <div class=\"flex items-center gap-2 text-white font-medium text-lg tracking-tight\">\n                <span class=\"iconify w-6 h-6\" data-icon=\"lucide:award\"></span> Rzetelność\n            </div>\n            <div class=\"flex items-center gap-2 text-white font-medium text-lg tracking-tight\">\n                <span class=\"iconify w-6 h-6\" data-icon=\"lucide:scale\"></span> Skuteczność\n            </div>\n            <div class=\"flex items-center gap-2 text-white font-medium text-lg tracking-tight\">\n                <span class=\"iconify w-6 h-6\" data-icon=\"lucide:clock\"></span> Szybkość\n            </div>\n        </div>\n    </section>\n\n    <!-- ABOUT SECTION (Reusing visual style to create \"more image feel\") -->\n    <section id=\"o-mnie\" class=\"py-24 bg-white relative\">\n        <div class=\"max-w-6xl mx-auto px-6 grid md:grid-cols-2 gap-16 items-center\">\n            <div class=\"relative order-2 md:order-1\">\n                <!-- Abstract styling representing an image placeholder or graphic element -->\n                <div class=\"relative aspect-[4/5] rounded-2xl overflow-hidden bg-slate-100\">\n                    <img src=\"https://bukowski-kielce.pl/wp-content/uploads/2024/06/IMG_2679-scaled-1.jpg\" class=\"absolute inset-0 w-full h-full object-cover grayscale contrast-125 brightness-110 hover:grayscale-0 transition duration-700\">\n                    <div class=\"absolute inset-0 bg-gradient-to-t from-navy-900/60 to-transparent\"></div>\n                    \n                    <div class=\"absolute bottom-6 left-6 right-6 p-6 glass-panel rounded-xl border border-white/20\">\n                        <p class=\"text-white text-sm italic\">\"Moim celem jest nie tylko wygrana, ale przede wszystkim przywrócenie spokoju klientowi.\"</p>\n                        <p class=\"text-gold-500 text-xs font-semibold mt-2 uppercase tracking-wider\">— Adw. Michał Bukowski</p>\n                    </div>\n                </div>\n                <!-- Decorative elements -->\n                <div class=\"absolute -bottom-8 -left-8 w-24 h-24 bg-gold-500/10 rounded-full blur-2xl\"></div>\n                <div class=\"absolute -top-8 -right-8 w-32 h-32 bg-navy-900/5 rounded-full blur-2xl\"></div>\n            </div>\n\n            <div class=\"order-1 md:order-2 space-y-6\">\n                <h2 class=\"text-3xl md:text-4xl font-semibold text-navy-900 tracking-tight\">\n                    Doświadczenie, które <br>daje przewagę.\n                </h2>\n                <div class=\"w-12 h-1 bg-gold-500 rounded-full\"></div>\n                <p class=\"text-slate-500 leading-relaxed text-lg\">\n                    Prawo to nie tylko przepisy, to przede wszystkim ludzie i ich historie. W swojej praktyce łączę głęboką wiedzę merytoryczną z empatią i zrozumieniem dla trudnej sytuacji klienta.\n                </p>\n                <p class=\"text-slate-500 leading-relaxed text-lg\">\n                    Specjalizuję się w prowadzeniu skomplikowanych procesów sądowych, gdzie liczy się każdy detal. Moja kancelaria to miejsce, gdzie Twój problem staje się moim zadaniem do rozwiązania.\n                </p>\n\n                <ul class=\"space-y-4 pt-4\">\n                    <li class=\"flex items-start gap-3\">\n                        <div class=\"w-6 h-6 rounded-full bg-gold-500/10 flex items-center justify-center text-gold-600 mt-0.5\">\n                            <span class=\"iconify w-3.5 h-3.5\" data-icon=\"lucide:check\"></span>\n                        </div>\n                        <span class=\"text-slate-700 font-medium\">Indywidualne podejście do każdej sprawy</span>\n                    </li>\n                    <li class=\"flex items-start gap-3\">\n                        <div class=\"w-6 h-6 rounded-full bg-gold-500/10 flex items-center justify-center text-gold-600 mt-0.5\">\n                            <span class=\"iconify w-3.5 h-3.5\" data-icon=\"lucide:check\"></span>\n                        </div>\n                        <span class=\"text-slate-700 font-medium\">Pełna poufność i dyskrecja adwokacka</span>\n                    </li>\n                    <li class=\"flex items-start gap-3\">\n                        <div class=\"w-6 h-6 rounded-full bg-gold-500/10 flex items-center justify-center text-gold-600 mt-0.5\">\n                            <span class=\"iconify w-3.5 h-3.5\" data-icon=\"lucide:check\"></span>\n                        </div>\n                        <span class=\"text-slate-700 font-medium\">Transparentne zasady rozliczeń</span>\n                    </li>\n                </ul>\n            </div>\n        </div>\n    </section>\n\n    <!-- SERVICES (Grid Layout) -->\n    <section id=\"specjalizacje\" class=\"py-24 bg-slate-50 border-y border-slate-200\">\n        <div class=\"max-w-6xl mx-auto px-6\">\n            <div class=\"text-center max-w-2xl mx-auto mb-16\">\n                <span class=\"text-gold-600 font-semibold uppercase tracking-widest text-xs mb-2 block\">Obszary praktyki</span>\n                <h2 class=\"text-3xl md:text-4xl font-semibold text-navy-900 tracking-tight\">W czym mogę pomóc?</h2>\n            </div>\n\n            <div class=\"grid md:grid-cols-3 gap-8\">\n                <!-- Service 1 -->\n                <div class=\"bg-white p-8 rounded-xl border border-slate-200 hover:border-gold-500/50 hover:shadow-glow transition-all duration-300 group\">\n                    <div class=\"w-12 h-12 bg-slate-50 rounded-lg border border-slate-100 flex items-center justify-center mb-6 text-navy-900 group-hover:bg-navy-900 group-hover:text-gold-500 transition-colors\">\n                        <span class=\"iconify w-6 h-6\" data-icon=\"lucide:gavel\"></span>\n                    </div>\n                    <h3 class=\"text-xl font-semibold text-navy-900 mb-3 group-hover:text-gold-600 transition-colors\">Prawo Karne</h3>\n                    <p class=\"text-slate-500 text-sm leading-relaxed mb-6\">\n                        Obrona w postępowaniu przygotowawczym i sądowym. Sprawy o przestępstwa pospolite, gospodarcze oraz skarbowe. Pomoc w sprawach aresztowych.\n                    </p>\n                    <a href=\"#\" class=\"text-xs font-semibold uppercase tracking-wide text-navy-900 flex items-center gap-1 group-hover:gap-2 transition-all\">\n                        Szczegóły <span class=\"iconify\" data-icon=\"lucide:arrow-right\"></span>\n                    </a>\n                </div>\n\n                <!-- Service 2 -->\n                <div class=\"bg-white p-8 rounded-xl border border-slate-200 hover:border-gold-500/50 hover:shadow-glow transition-all duration-300 group relative overflow-hidden\">\n                    <div class=\"absolute top-0 right-0 p-2 opacity-5\">\n                         <span class=\"iconify w-32 h-32\" data-icon=\"lucide:heart-handshake\"></span>\n                    </div>\n                    <div class=\"w-12 h-12 bg-slate-50 rounded-lg border border-slate-100 flex items-center justify-center mb-6 text-navy-900 group-hover:bg-navy-900 group-hover:text-gold-500 transition-colors relative z-10\">\n                        <span class=\"iconify w-6 h-6\" data-icon=\"lucide:users\"></span>\n                    </div>\n                    <h3 class=\"text-xl font-semibold text-navy-900 mb-3 group-hover:text-gold-600 transition-colors relative z-10\">Prawo Rodzinne</h3>\n                    <p class=\"text-slate-500 text-sm leading-relaxed mb-6 relative z-10\">\n                        Rozwody, podział majątku, alimenty, władza rodzicielska. Prowadzę sprawy z wyczuciem i dbałością o interesy Klienta oraz dobro małoletnich.\n                    </p>\n                    <a href=\"#\" class=\"text-xs font-semibold uppercase tracking-wide text-navy-900 flex items-center gap-1 group-hover:gap-2 transition-all relative z-10\">\n                        Szczegóły <span class=\"iconify\" data-icon=\"lucide:arrow-right\"></span>\n                    </a>\n                </div>\n\n                <!-- Service 3 -->\n                <div class=\"bg-white p-8 rounded-xl border border-slate-200 hover:border-gold-500/50 hover:shadow-glow transition-all duration-300 group\">\n                    <div class=\"w-12 h-12 bg-slate-50 rounded-lg border border-slate-100 flex items-center justify-center mb-6 text-navy-900 group-hover:bg-navy-900 group-hover:text-gold-500 transition-colors\">\n                        <span class=\"iconify w-6 h-6\" data-icon=\"lucide:briefcase\"></span>\n                    </div>\n                    <h3 class=\"text-xl font-semibold text-navy-900 mb-3 group-hover:text-gold-600 transition-colors\">Obsługa Biznesu</h3>\n                    <p class=\"text-slate-500 text-sm leading-relaxed mb-6\">\n                        Stała obsługa prawna firm, przygotowywanie i opiniowanie umów, windykacja należności, spory sądowe w sprawach gospodarczych.\n                    </p>\n                    <a href=\"#\" class=\"text-xs font-semibold uppercase tracking-wide text-navy-900 flex items-center gap-1 group-hover:gap-2 transition-all\">\n                        Szczegóły <span class=\"iconify\" data-icon=\"lucide:arrow-right\"></span>\n                    </a>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    <!-- DARK CTA SECTION -->\n    <section class=\"py-20 bg-navy-900 relative overflow-hidden\">\n        <!-- Abstract Background -->\n        <div class=\"absolute inset-0 opacity-10\">\n            <svg class=\"w-full h-full\" viewBox=\"0 0 100 100\" preserveAspectRatio=\"none\">\n                <path d=\"M0 100 L100 0 L100 100 Z\" fill=\"#ffffff\" />\n            </svg>\n        </div>\n        \n        <div class=\"max-w-4xl mx-auto px-6 text-center relative z-10\">\n            <h2 class=\"text-3xl md:text-5xl font-semibold text-white tracking-tight mb-6\">Twój problem wymaga <br>profesjonalnego rozwiązania.</h2>\n            <p class=\"text-slate-400 text-lg mb-10 max-w-2xl mx-auto\">Nie czekaj, aż sprawa się skomplikuje. Skontaktuj się ze mną, aby ustalić najlepszą strategię działania.</p>\n            \n            <div class=\"flex flex-col sm:flex-row justify-center gap-4\">\n                <a href=\"tel:+48664314578\" class=\"px-8 py-4 bg-gold-500 text-navy-900 rounded font-semibold hover:bg-gold-600 transition flex items-center justify-center gap-2\">\n                    <span class=\"iconify\" data-icon=\"lucide:phone-call\"></span>\n                    Zadzwoń: 664 314 578\n                </a>\n                <button onclick=\"document.getElementById('contact-card').scrollIntoView({behavior: 'smooth'})\" class=\"px-8 py-4 bg-transparent border border-white/20 text-white rounded font-medium hover:bg-white/10 transition\">\n                    Wypełnij formularz\n                </button>\n            </div>\n        </div>\n    </section>\n\n    <!-- FOOTER -->\n    <footer class=\"bg-navy-900 border-t border-white/10 text-slate-400 py-16 text-sm\">\n        <div class=\"max-w-6xl mx-auto px-6 grid md:grid-cols-4 gap-12\">\n            <div class=\"col-span-1 md:col-span-2\">\n                <div class=\"flex items-center gap-2 text-white mb-6\">\n                    <span class=\"iconify w-6 h-6 text-gold-500\" data-icon=\"lucide:scale\"></span>\n                    <span class=\"font-semibold tracking-tight\">Kancelaria Adwokacka</span>\n                </div>\n                <p class=\"mb-6 max-w-sm\">Profesjonalna pomoc prawna świadczona z najwyższą starannością i poszanowaniem zasad etyki adwokackiej.</p>\n                <div class=\"flex gap-4\">\n                    <a href=\"#\" class=\"w-10 h-10 rounded bg-white/5 flex items-center justify-center hover:bg-gold-500 hover:text-navy-900 transition\">\n                        <span class=\"iconify w-5 h-5\" data-icon=\"lucide:facebook\"></span>\n                    </a>\n                    <a href=\"#\" class=\"w-10 h-10 rounded bg-white/5 flex items-center justify-center hover:bg-gold-500 hover:text-navy-900 transition\">\n                        <span class=\"iconify w-5 h-5\" data-icon=\"lucide:linkedin\"></span>\n                    </a>\n                </div>\n            </div>\n            \n            <div>\n                <h4 class=\"text-white font-medium mb-6 uppercase tracking-wider text-xs\">Kontakt</h4>\n                <ul class=\"space-y-4\">\n                    <li class=\"flex items-start gap-3\">\n                        <span class=\"iconify mt-0.5 text-gold-500\" data-icon=\"lucide:map-pin\"></span>\n                        Kielce, ul. Sienkiewicza 12/3\n                    </li>\n                    <li class=\"flex items-center gap-3\">\n                        <span class=\"iconify text-gold-500\" data-icon=\"lucide:phone\"></span>\n                        <a href=\"tel:+48664314578\" class=\"hover:text-white transition\">+48 664 314 578</a>\n                    </li>\n                    <li class=\"flex items-center gap-3\">\n                        <span class=\"iconify text-gold-500\" data-icon=\"lucide:mail\"></span>\n                        <a href=\"mailto:kontakt@kancelaria.pl\" class=\"hover:text-white transition\">kontakt@kancelaria.pl</a>\n                    </li>\n                </ul>\n            </div>\n\n            <div>\n                <h4 class=\"text-white font-medium mb-6 uppercase tracking-wider text-xs\">Informacje</h4>\n   